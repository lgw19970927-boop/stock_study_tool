{
  "name": "stock-study-tool",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "postcss app/static/css/input.css -o app/static/css/tailwind.output.css",
    "watch:css": "postcss app/static/css/input.css -o app/static/css/tailwind.output.css --watch",
    "build:css:prod": "postcss app/static/css/input.css -o app/static/css/tailwind.output.css --env production"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.3"
  }
}
